{{ header }}

program {{ name }}_test_main
   use TesterMain
   use {{ name }}

   implicit none
{% for case in cases %}
   ! Test {{ loop.index }}: {{ case["description"] }}
{%- if case["property"] == "squareOfSum" %}
   call assert_equal({{ case["expected"] }}, square_of_sum({{ case["input"]["number"] }}), "{{ case["description"] }}")
{%- elif case["property"] == "sumOfSquares" %}
   call assert_equal({{ case["expected"] }}, sum_of_squares({{ case["input"]["number"] }}), "{{ case["description"] }}")
{%- elif case["property"] == "differenceOfSquares" %}
   call assert_equal({{ case["expected"] }}, difference({{ case["input"]["number"] }}), "{{ case["description"] }}")
{%- endif %}
{% endfor %}
   call test_report()

end program
