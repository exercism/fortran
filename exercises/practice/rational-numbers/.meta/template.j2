{{ header }}

program {{ name }}_test_main
   use TesterMain
   use {{ name }}

   implicit none
{% for case in cases %}
   ! Test {{ loop.index }}: {{ case["description"] }}
{%- if case["property"] in ["add", "sub", "mul", "div"] %}
   call assert_equal({{ case["expected"] }}, {{ case["property"] }}({{ case["input"]["r1"] }}, {{ case["input"]["r2"] }}), "{{ case["description"] }}")
{%- elif case["property"] == "abs" %}
   call assert_equal({{ case["expected"] }}, rational_abs({{ case["input"]["r"] }}), &
   & "{{ case["description"] }}")
{%- elif case["property"] == "exprational" %}
   call assert_equal({{ case["expected"] }}, rational_to_pow({{ case["input"]["r"] }}, {{ case["input"]["n"] }}), &
   & "{{ case["description"] }}")
{%- elif case["property"] == "expreal" %}
   call assert_equal({{ "%0.1f" | format(case["expected"]) }}, real_to_rational_pow({{ case["input"]["x"] }}, {{ case["input"]["r"] }}), &
   & "{{ case["description"] }}")
{%- elif case["property"] == "reduce" %}
   call assert_equal({{ case["expected"] }}, reduce({{ case["input"]["r"] }}), &
   & "{{ case["description"] }}")
{%- else %}
   UNHANDLED {{ case }}
{%- endif %}
{% endfor %}
   call test_report()

end program
